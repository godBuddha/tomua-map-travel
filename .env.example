# Server
NODE_ENV=development
PORT=5001

# Database
DB_PASSWORD=change_me_strong_password
DB_USER=tomua_admin
DB_NAME=tomua_tourism

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_min_32_chars_secret
JWT_REFRESH_SECRET=change_me_min_32_chars_refresh_secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Redis
REDIS_URL=redis://localhost:6379

# Admin (change immediately!)
ADMIN_EMAIL=admin@tomua.vn
ADMIN_PASSWORD=change_me_strong_password
ADMIN_NAME=Administrator

# CTV
CTV_PASSWORD=change_me_strong_password

# OSRM
OSRM_URL=http://router.project-osrm.org
