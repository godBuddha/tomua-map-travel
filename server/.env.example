# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://tomua_admin:CHANGE_ME@localhost:5432/tomua_tourism

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_here_change_this
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here_change_this
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# OSRM
OSRM_URL=http://router.project-osrm.org

# Admin seed
ADMIN_EMAIL=admin@tomua.vn
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=Administrator
