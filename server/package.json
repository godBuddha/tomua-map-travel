{
  "name": "tomua-map-travel-server",
  "version": "1.0.0",
  "description": "Backend API for To Mua Tourism Map",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "NODE_ENV=test jest --forceExit --detectOpenHandles",
    "test:unit": "NODE_ENV=test jest tests/unit --forceExit",
    "test:integration": "NODE_ENV=test jest tests/integration --forceExit --detectOpenHandles",
    "test:coverage": "NODE_ENV=test jest --coverage --forceExit",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "otplib": "^13.4.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "redis": "^6.1.0",
    "sharp": "^0.35.2",
    "slugify": "^1.6.6",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.9.4",
    "supertest": "^6.3.4"
  }
}
