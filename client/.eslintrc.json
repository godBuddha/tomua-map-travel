{
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "L": "readonly",
    "I18nNew": "readonly",
    "TomuaConfig": "readonly",
    "I18n": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-undef": "off",
    "prefer-const": "warn",
    "no-var": "error"
  }
}
